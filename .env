# Server
NODE_ENV=development
PORT=5000

# MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=windosutils_db
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret 
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_TTL_SECONDS=600
OTP_LENGTH=6

# Email (Nodemailer SMTP)
SMTP_HOST=windowsutils.com
SMTP_PORT=465
SMTP_SECURE=false
SMTP_USER=info@windowsutils.com
