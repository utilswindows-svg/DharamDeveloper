# Server
NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auth_db
DB_USER=root
DB_PASSWORD=root


# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_TTL_SECONDS=600
OTP_LENGTH=6

# ---- Email (Nodemailer SMTP) ----
# Works with Gmail App Passwords, SendGrid, Mailgun, Brevo, AWS SES SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_or_smtp_key
EMAIL_FROM="Auth App <no-reply@yourdomain.com>"

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555555555

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- PayPal ----
# Get from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
